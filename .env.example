APP_ENV=development
HOST=0.0.0.0
PORT=8000

# LiveKit Server local (docker compose). Valores do livekit.yaml default.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# OpenRouter LLM (chave ja existente — copiar do agente-consultoria/.env)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash

# Resend email (chave ja existente)
RESEND_API_KEY=re_...
EMAIL_FROM=AutoPME <noreply@caiporalabs.com>
DEMO_NOTIFY_EMAIL=demo.consultoria@caiporalabs.com

# WhatsApp Baileys gateway (processo Node sidecar na porta 3001)
BAILEYS_GATEWAY_URL=http://localhost:3001

# STT/TTS locais
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=pt
TTS_ENGINE=piper
TTS_VOICE=pt-PT

DEFAULT_NICHE=dental
ADMIN_PASSWORD=democonsultoria123

# Persistencia leve (historico de demos, sqlite3 stdlib).
# Local: ./data. Em Railway, montar um volume e apontar para o mount (ex: /app/data).
STORAGE_DIR=./data

# ---- Notion CRM (opcional) ----
# Liga a demo a Pipeline de Clientes do Notion: ao fim da demo, o diagnostico
# cria o cartao do prospect no funil. Sem isto, o botao fica oculto.
# 1) Criar integracao interna: https://www.notion.so/my-integrations -> copiar o "Internal Integration Secret"
# 2) Abrir a base "Pipeline de Clientes" no Notion -> ... -> Connections -> adicionar a integracao
# 3) NOTION_PIPELINE_DATABASE_ID = id da database (32 chars no URL da base)
NOTION_TOKEN=
NOTION_PIPELINE_DATABASE_ID=4cb95d4824a342a292de3731b8c39c90

# ---- Voz modular (Vapi | browser) ----
# Provider ativo. Default seguro: browser.
# vapi so ativa quando tambem existir VAPI_PUBLIC_KEY.
VOICE_PROVIDER=browser
VOICE_DEFAULT_LANGUAGE=pt-PT

# Chaves Vapi JA EXISTENTES (copiar de agente-consultoria/.env — sem novos registos):
VAPI_API_KEY=
VAPI_ASSISTANT_ID_INBOUND=
VAPI_ASSISTANT_ID_OUTBOUND=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# Vapi Web SDK no browser (NAO esta no .env de referencia). Obter no dashboard Vapi:
# Settings -> API Keys -> public key. Sem ela, o dashboard usa o modo browser.
VAPI_PUBLIC_KEY=

# Voz dentro do Vapi (Azure Neural PT-PT). Por idioma o provider mapeia automaticamente.
VAPI_VOICE_PROVIDER=azure
VAPI_VOICE_ID=pt-PT-RaquelNeural
